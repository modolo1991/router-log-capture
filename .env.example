# Collector type: sagemcom | syslog | http_scraper
COLLECTOR_TYPE=sagemcom

# Timezone of the machine running the app (and your router).
# Use a tz database name: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# Examples: Australia/Sydney  Europe/London  America/New_York  UTC
TZ=Australia/Sydney

# Router IP address
ROUTER_IP=192.168.0.1

# Sagemcom settings (only used when COLLECTOR_TYPE=sagemcom)
ROUTER_USERNAME=admin
ROUTER_PASSWORD=your_router_password

# Syslog settings (only used when COLLECTOR_TYPE=syslog)
SYSLOG_PORT=514
SYSLOG_PROTOCOL=udp

# HTTP scraper settings (only used when COLLECTOR_TYPE=http_scraper)
ROUTER_LOGIN_PATH=/cgi-bin/login.cgi
ROUTER_LOGIN_USERNAME_FIELD=username
ROUTER_LOGIN_PASSWORD_FIELD=password
ROUTER_LOG_PATH=/maintenance/logs
HTTP_SCRAPER_PARSER=optus

# Collection interval in seconds
POLL_INTERVAL_SECONDS=30

# Web UI port
API_PORT=8080

# MCP server port (used by AI assistants to query router logs)
MCP_PORT=8081

# Database path inside the container (keep as-is)
DATABASE_PATH=/data/logs.db
